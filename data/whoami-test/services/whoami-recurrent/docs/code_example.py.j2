import requests
import os

response = requests.post(
    os.environ.get('SERVICE_BASE_URL'),
    headers={
        "Authorization": f"Bearer {os.environ.get('UNITYSVC_API_KEY', '')}",
        "Content-Type": "application/json",
    },
    json={"url": "https://example.com", "port": 443},
)
print(response)
